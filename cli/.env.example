# Codebuff CLI environment example
CODEBUFF_CLI_VERSION=0.1.0-dev
CODEBUFF_API_URL=https://api.codebuff.com
# Path where the CLI persists the auth token after login.
# Defaults to $HOME/.codebuff/auth.json
# CODEBUFF_AUTH_FILE=
# When true, the CLI runs in restricted "freebuff" mode.
IS_FREEBUFF=false
LOG_LEVEL=info
