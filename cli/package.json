{
  "name": "codebuff-tui",
  "version": "0.1.0",
  "description": "Terminal AI coding assistant powered by Fireworks AI (GLM-5.1 + Kimi K2.6) with strength-based model routing.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "codebuff-tui": "./bin/codebuff-tui.js"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "cli",
    "tui",
    "ai",
    "coding-assistant",
    "fireworks",
    "glm",
    "kimi",
    "opentui"
  ],
  "scripts": {
    "dev": "bun run scripts/prebuild-agents.ts && bun run src/index.tsx",
    "build": "bun run scripts/build.ts",
    "build:binary": "bun run scripts/build-binary.ts",
    "prepublishOnly": "bun run build",
    "release": "bun run scripts/release.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opentui/core": "0.1.87",
    "@opentui/react": "0.1.87",
    "commander": "^14.0.1",
    "pino": "9.4.0",
    "pino-pretty": "^11.2.2",
    "react": "^19.0.0",
    "react-reconciler": "^0.32.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-reconciler": "^0.28.9",
    "typescript": "5.5.4"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
