{
  "name": "@codebuff/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "codebuff-tui": "./bin/codebuff-tui"
  },
  "scripts": {
    "dev": "bun run scripts/prebuild-agents.ts && bun run src/index.tsx",
    "build": "bun build src/index.tsx --outdir dist --target bun",
    "build:binary": "bun run scripts/build-binary.ts",
    "release": "bun run scripts/release.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opentui/core": "0.1.87",
    "@opentui/react": "0.1.87",
    "commander": "^14.0.1",
    "pino": "9.4.0",
    "pino-pretty": "^11.2.2",
    "react": "^19.0.0",
    "react-reconciler": "^0.32.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-reconciler": "^0.28.9",
    "typescript": "5.5.4"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
