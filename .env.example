# Codebuff CLI environment example
CODEBUFF_CLI_VERSION=0.1.0-dev
CODEBUFF_API_URL=https://orbitron--pastelsjuice8t.replit.app
# Path where the CLI persists the auth token after login.
# CODEBUFF_AUTH_FILE=$HOME/.codebuff/auth.json
IS_FREEBUFF=false
LOG_LEVEL=info

