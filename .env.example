# Codebuff CLI environment example
CODEBUFF_CLI_VERSION=0.1.0-dev
CODEBUFF_API_URL=https://api.fireworks.ai/inference/v1
# Path where the CLI persists the auth token after login.
# CODEBUFF_AUTH_FILE=$HOME/.codebuff/auth.json
IS_FREEBUFF=false
LOG_LEVEL=info

# Fireworks AI backend
FIREWORKS_API_KEY=fw_your_key_here
FIREWORKS_MODEL_GLM=accounts/fireworks/models/glm-5p1
FIREWORKS_MODEL_KIMI=accounts/fireworks/models/kimi-k2p6
