# Codebuff CLI environment example
CODEBUFF_CLI_VERSION=0.1.0-dev
CODEBUFF_API_URL=https://orbitron--pastelsjuice8t.replit.app
# Path where the CLI persists the auth token after login.
# CODEBUFF_AUTH_FILE=$HOME/.codebuff/auth.json
IS_FREEBUFF=false
LOG_LEVEL=info

# Orbitron API key (sk-sb-v1-...) — get one at https://orbitron--pastelsjuice8t.replit.app/keys
ORBITRON_API_KEY=sk-sb-v1-your_key_here

# Default models (codebuff CLI Default-mode model, bare orbitron IDs)
FIREWORKS_MODEL_GLM=claude-opus-4.7
FIREWORKS_MODEL_KIMI=claude-opus-4.7
