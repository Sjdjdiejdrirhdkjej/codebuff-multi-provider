{
  "name": "codebuff-tui",
  "version": "0.1.0",
  "description": "Terminal AI coding assistant powered by Fireworks AI (GLM-5.1 + Kimi K2.6) with strength-based model routing.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "codebuff-tui": "./bin/codebuff-tui.js"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "cli",
    "tui",
    "ai",
    "coding-assistant",
    "fireworks",
    "glm",
    "kimi",
    "opentui"
  ],
  "scripts": {
    "dev": "tsx scripts/prebuild-agents.ts && tsx src/index.tsx",
    "start": "node dist/index.js",
    "build": "bun run scripts/build.ts",
    "build:binary": "bun run scripts/build-binary.ts",
    "prepublishOnly": "bun run build",
    "release": "bun run scripts/release.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "dependencies": {
    "@opentui/core": "0.1.87",
    "@opentui/react": "0.1.87",
    "commander": "^14.0.1",
    "pino": "9.4.0",
    "pino-pretty": "^11.2.2",
    "react": "^19.0.0",
    "react-reconciler": "^0.32.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "@types/node": "^22.9.0",
    "@types/react": "19.2.14",
    "@types/react-reconciler": "^0.28.9",
    "@typescript-eslint/eslint-plugin": "^6.17",
    "bun-types": "1.3.11",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "ignore": "^6.0.2",
    "prettier": "^3.7.4",
    "ts-pattern": "^5.9.0",
    "tsx": "^4.19.2",
    "typescript": "5.5.4",
    "typescript-eslint": "^7.17.0"
  },
  "overrides": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "zod": "^4.2.1",
    "signal-exit": "3.0.7"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.3.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "bun@1.3.11"
}
