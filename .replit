modules = ["bun-1.3", "nodejs-20"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Codebuff CLI"

[[workflows.workflow]]
name = "Codebuff CLI"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd cli && bun src/index.tsx --help && echo '' && echo '=== CLI ready. Run \"bun cli/src/index.tsx\" in a shell for the interactive TUI. Tailing log file... ===' && mkdir -p $HOME/.codebuff/logs && touch $HOME/.codebuff/logs/cli.log && tail -f $HOME/.codebuff/logs/cli.log"

[workflows.workflow.metadata]
outputType = "console"
